<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Beeper Content Provider permissions -->
    <uses-permission android:name="com.beeper.android.permission.READ_PERMISSION" />
    <uses-permission android:name="com.beeper.android.permission.SEND_PERMISSION" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BeeperProxy">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Content Provider that forwards queries to Beeper -->
        <provider
            android:name=".BeeperProxyProvider"
            android:authorities="com.beeperproxy.provider"
            android:exported="true"
            android:grantUriPermissions="true" />

        <!-- Intent Receiver for Tasker/Automate bridge -->
        <receiver
            android:name=".BeeperIntentReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.beeperproxy.QUERY" />
                <action android:name="com.beeperproxy.INSERT" />
            </intent-filter>
        </receiver>

    </application>

    <queries>
        <package android:name="com.beeper.android" />
    </queries>

</manifest>
