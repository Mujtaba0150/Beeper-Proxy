<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Op buttons row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_op_chats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chats"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/btn_secondary"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_op_chats_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chats Count"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/btn_secondary"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_op_messages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messages"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/btn_secondary"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_op_messages_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messages Count"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/btn_secondary"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_op_contacts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contacts"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/btn_secondary"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_op_contacts_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contacts Count"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/btn_secondary"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_op_insert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Insert"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/btn_secondary"
                android:textColor="@color/text_primary" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Scrollable fields area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Shared: limit -->
            <LinearLayout
                android:id="@+id/group_limit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIMIT"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent"
                    app:hintTextColor="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_limit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. 10 (default 100)"
                        android:inputType="number"
                        android:textColor="@color/text_primary" />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Shared: offset -->
            <LinearLayout
                android:id="@+id/group_offset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OFFSET"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent"
                    app:hintTextColor="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_offset"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Pagination offset"
                        android:inputType="number"
                        android:textColor="@color/text_primary" />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Query ops: columns to return (projection) -->
            <LinearLayout
                android:id="@+id/group_columns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COLUMNS TO RETURN (CSV, blank = all)"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent"
                    app:hintTextColor="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_columns"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. roomId,title,unreadCount"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Filters the cursor projection for Content Provider queries, and the per-column array extras returned over Broadcast Intent."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- Chats/Messages/Contacts: roomIds filter -->
            <LinearLayout
                android:id="@+id/group_room_ids_filter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ROOM IDS (CSV)"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent"
                    app:hintTextColor="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_room_ids_filter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="!room1:server.com,!room2:server.com"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace" />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Chats only: isUnread -->
            <LinearLayout
                android:id="@+id/group_is_unread"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <CheckBox
                    android:id="@+id/cb_is_unread"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/accent"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unread only (isUnread=1)"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Chats only: isLowPriority -->
            <LinearLayout
                android:id="@+id/group_is_low_priority"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <CheckBox
                    android:id="@+id/cb_is_low_priority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/accent"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Low priority only (isLowPriority=1)"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Chats only: isArchived -->
            <LinearLayout
                android:id="@+id/group_is_archived"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <CheckBox
                    android:id="@+id/cb_is_archived"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/accent"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Archived only (isArchived=1)"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Chats only: showInAllChats -->
            <LinearLayout
                android:id="@+id/group_show_in_all_chats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <CheckBox
                    android:id="@+id/cb_show_in_all_chats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/accent"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show in all chats only (showInAllChats=1)"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Chats + Contacts: protocol -->
            <LinearLayout
                android:id="@+id/group_protocol"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROTOCOL"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent"
                    app:hintTextColor="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_protocol"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. whatsapp, signal, telegram"
                        android:textColor="@color/text_primary" />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Messages only: search query -->
            <LinearLayout
                android:id="@+id/group_message_query"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SEARCH QUERY"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent"
                    app:hintTextColor="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_message_query"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Search term"
                        android:textColor="@color/text_primary" />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Messages only: senderId -->
            <LinearLayout
                android:id="@+id/group_sender_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SENDER ID"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent"
                    app:hintTextColor="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_sender_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Filter by sender contact ID"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace" />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Messages only: contextBefore / contextAfter -->
            <LinearLayout
                android:id="@+id/group_context"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SEARCH CONTEXT"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/accent"
                        app:hintTextColor="@color/text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_context_before"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="contextBefore"
                            android:inputType="number"
                            android:textColor="@color/text_primary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/accent"
                        app:hintTextColor="@color/text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_context_after"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="contextAfter"
                            android:inputType="number"
                            android:textColor="@color/text_primary" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- Messages only: openAtUnread -->
            <LinearLayout
                android:id="@+id/group_open_at_unread"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <CheckBox
                    android:id="@+id/cb_open_at_unread"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/accent"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open at unread (requires exactly one roomId)"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Contacts only: search query -->
            <LinearLayout
                android:id="@+id/group_contact_query"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SEARCH CONTACTS"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent"
                    app:hintTextColor="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_contact_query"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Name or identifier"
                        android:textColor="@color/text_primary" />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Contacts only: senderIds -->
            <LinearLayout
                android:id="@+id/group_sender_ids"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SENDER IDS (CSV)"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent"
                    app:hintTextColor="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_sender_ids"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@alice:server.com,@bob:server.com"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace" />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Insert fields: roomId + text -->
            <LinearLayout
                android:id="@+id/group_insert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ROOM ID"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent"
                    app:hintTextColor="@color/text_secondary"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_room_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="!roomId:server.com"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MESSAGE TEXT"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent"
                    app:hintTextColor="@color/text_secondary"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_message_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Your message"
                        android:textColor="@color/text_primary"
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:gravity="top" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Generated query display -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GENERATED QUERY"
                android:textColor="@color/accent"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.core.widget.NestedScrollView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="120dp"
                    android:background="@color/token_bg"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/tv_generated_query"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:textIsSelectable="true" />

                </androidx.core.widget.NestedScrollView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_copy_query"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="top"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/ic_copy"
                    app:iconTint="@color/text_primary"
                    app:iconPadding="0dp"
                    app:iconGravity="textStart"
                    app:iconSize="20dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    app:cornerRadius="8dp"
                    app:backgroundTint="@color/btn_secondary"
                    style="@style/Widget.MaterialComponents.Button.Icon"
                    android:contentDescription="Copy generated query" />

            </LinearLayout>

            <!-- Generated intent command display -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GENERATED BROADCAST INTENT COMMAND"
                android:textColor="@color/accent"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.core.widget.NestedScrollView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="160dp"
                    android:background="@color/token_bg"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/tv_generated_intent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:textIsSelectable="true" />

                </androidx.core.widget.NestedScrollView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_copy_intent"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="top"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/ic_copy"
                    app:iconTint="@color/text_primary"
                    app:iconPadding="0dp"
                    app:iconGravity="textStart"
                    app:iconSize="20dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    app:cornerRadius="8dp"
                    app:backgroundTint="@color/btn_secondary"
                    style="@style/Widget.MaterialComponents.Button.Icon"
                    android:contentDescription="Copy generated intent command" />

            </LinearLayout>

            <!-- Output columns -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OUTPUT COLUMNS"
                android:textColor="@color/accent"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_output_columns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/token_bg"
                android:padding="12dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textIsSelectable="true" />

            <!-- Loading indicator (shown while test runs, hides result box) -->
            <LinearLayout
                android:id="@+id/group_test_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tv_loading_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Querying…"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Test result -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/sv_test_result"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="@color/token_bg"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_test_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true" />

            </androidx.core.widget.NestedScrollView>

            <!-- Test button at the bottom of scroll -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_test"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Run Test"
                app:backgroundTint="@color/accent"
                android:textColor="@color/bg_dark"
                app:cornerRadius="8dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom navigation bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_bg"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
