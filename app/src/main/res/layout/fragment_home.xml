<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header with logo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_logo"
                android:layout_marginEnd="14dp"
                android:contentDescription="Beeper Proxy logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Beeper Proxy"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Content Provider Bridge"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardBackgroundColor="@color/card_bg"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="4dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AUTH TOKEN"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />
                <TextView
                    android:id="@+id/tv_auth_token"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:background="@color/token_bg"
                    android:padding="12dp"
                    android:textIsSelectable="true"
                    android:layout_marginBottom="16dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_copy_token"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Copy"
                        android:textColor="@color/text_primary"
                        app:backgroundTint="@color/btn_secondary"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="8dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_refresh_token"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Refresh Token"
                        app:backgroundTint="@color/accent"
                        android:textColor="@color/bg_dark"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardBackgroundColor="@color/card_bg"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="4dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEEPER PERMISSIONS"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />
                <TextView
                    android:id="@+id/tv_permission_read"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="READ_PERMISSION: Checking..."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:id="@+id/tv_permission_send"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SEND_PERMISSION: Checking..."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="14dp" />
                <TextView
                    android:id="@+id/tv_permission_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap below to grant Beeper permissions."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="14dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_request_permissions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Grant Beeper Permissions"
                    app:backgroundTint="@color/accent"
                    android:textColor="@color/bg_dark"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardBackgroundColor="@color/card_bg"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="4dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEST QUERY"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_test_chats"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chats"
                        android:textColor="@color/text_primary"
                        app:backgroundTint="@color/btn_secondary"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="6dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_test_messages"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Messages"
                        android:textColor="@color/text_primary"
                        app:backgroundTint="@color/btn_secondary"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="6dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_test_contacts"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Contacts"
                        android:textColor="@color/text_primary"
                        app:backgroundTint="@color/btn_secondary"
                        app:cornerRadius="8dp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/group_test_loading"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/token_bg"
                    android:visibility="gone">
                    <ProgressBar
                        android:id="@+id/progress_bar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp" />
                    <TextView
                        android:id="@+id/tv_loading_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Querying…"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
                <androidx.core.widget.NestedScrollView
                    android:id="@+id/sv_test_result"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:background="@color/token_bg">
                    <TextView
                        android:id="@+id/tv_test_result"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tap a button to run a test query via the proxy."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:padding="12dp"
                        android:textIsSelectable="true" />
                </androidx.core.widget.NestedScrollView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardBackgroundColor="@color/card_bg"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROXY AUTHORITY"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="content://com.beeperproxy.provider/chats?authToken=TOKEN"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="content://com.beeperproxy.provider/messages?authToken=TOKEN"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="content://com.beeperproxy.provider/contacts?authToken=TOKEN"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
