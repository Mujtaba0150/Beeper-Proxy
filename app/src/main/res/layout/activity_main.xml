<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Beeper Proxy"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Content Provider Bridge"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <!-- Auth Token Card -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardBackgroundColor="@color/card_bg"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AUTH TOKEN"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tv_auth_token"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:background="@color/token_bg"
                    android:padding="12dp"
                    android:textIsSelectable="true"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_copy_token"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Copy"
                        android:textColor="@color/text_primary"
                        app:backgroundTint="@color/btn_secondary"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_refresh_token"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Refresh Token"
                        app:backgroundTint="@color/accent"
                        android:textColor="@color/bg_dark"
                        app:cornerRadius="8dp" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Permissions Card -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardBackgroundColor="@color/card_bg"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEEPER PERMISSIONS"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tv_permission_read"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="READ_PERMISSION: Checking..."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_permission_send"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SEND_PERMISSION: Checking..."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:id="@+id/tv_permission_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap below to grant Beeper permissions."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_request_permissions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Grant Beeper Permissions"
                    app:backgroundTint="@color/accent"
                    android:textColor="@color/bg_dark"
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Usage hint -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardBackgroundColor="@color/card_bg"
            card_view:cardCornerRadius="12dp"
            card_view:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROXY AUTHORITY"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="content://com.beeperproxy.provider/chats?authToken=TOKEN"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="content://com.beeperproxy.provider/messages?authToken=TOKEN"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="content://com.beeperproxy.provider/contacts?authToken=TOKEN"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
